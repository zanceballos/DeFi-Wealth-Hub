# Enable parser backends (hybrid recommended)
PIPELINE_ENABLE_TEXTRACT=true
PIPELINE_ENABLE_QWENVL=true

# Set true only if you want to skip Textract and use Qwen-only for PDF/image
PIPELINE_QWEN_ONLY=false

# Escalation policy (Textract + rules -> Qwen)
PIPELINE_QWEN_AMBIGUITY_THRESHOLD=0.85
PIPELINE_TEXTRACT_MIN_LINES=8
PIPELINE_RULES_MIN_CONFIDENCE=0.8

# Textract credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Local Qwen2 settings
QWENVL_MODEL_ID=Qwen/Qwen2-VL-2B-Instruct
QWENVL_USE_4BIT=true
QWENVL_MAX_NEW_TOKENS=768
